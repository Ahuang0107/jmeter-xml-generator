            <hashTree>
                <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="Login Staff GPN &amp; Email"
                            enabled="true">
                    <stringProp name="delimiter">,</stringProp>
                    <stringProp name="fileEncoding"></stringProp>
