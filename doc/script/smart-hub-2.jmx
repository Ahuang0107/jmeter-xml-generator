                    <hashTree/>
                    <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor"
                                        testname="随机生成startDate和endDate" enabled="true">
                        <stringProp name="cacheKey">true</stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="script">def random=org.apache.commons.lang3.RandomUtils.nextLong(0,
                            28338681000)

                            vars.put(&quot;startDate&quot;,Long.toString(1669338030523-random))
                            vars.put(&quot;endDate&quot;,Long.toString(1675040430523-random))
                        </stringProp>
                        <stringProp name="scriptLanguage">groovy</stringProp>
                    </JSR223PreProcessor>
                    <hashTree/>
                    <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor"
                                         testname="join所有booking的engageId" enabled="true">
                        <stringProp name="cacheKey">true</stringProp>
                        <stringProp name="filename"></stringProp>
                        <stringProp name="parameters"></stringProp>
                        <stringProp name="script">import groovy.json.*

                            def response = prev.getResponseDataAsString()
                            def json = new JsonSlurper().parseText(response)

                            def data=json.data

                            def list = []

                            data.each{ staffBookings -&gt;
                            staffBookings.value.each{booking-&gt;
                            list.add(booking.engagementCodeId)
                            }
                            }

                            vars.put(&quot;engagementIds&quot;,list.unique().collect{it}.join(&quot;,&quot;))
                        </stringProp>
                        <stringProp name="scriptLanguage">groovy</stringProp>
                    </JSR223PostProcessor>
                    <hashTree/>
                </hashTree>
                <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Controller"
                              enabled="true">
                    <stringProp name="IfController.condition">
